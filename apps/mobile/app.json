{
  "expo": {
    "name": "Forkmarked",
    "slug": "forkmarked",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "forkmarked",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F97316"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.srjlabs.forkmarked",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F97316"
      },
      "package": "com.srjlabs.forkmarked"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e92848dc-2b55-47c3-a590-ff7032eea0cd"
      }
    },
    "owner": "srjlabs-llc"
  }
}
